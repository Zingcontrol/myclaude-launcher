#!/usr/bin/env zsh

# myclaude — Unified Claude Code launcher
# Three doors: Business (zingcontrol only), Personal (reads all, writes utahdiver), Bench (empty)
# Same script, any machine. Projects defined in ~/.myclaude/projects.conf
#
# Per-door MCP loading via --mcp-config / --strict-mcp-config flags.
# Door MCP configs at ~/.myclaude/mcp/{business,personal,bench}.json
#
# Flags:
#   -e, --edit       Edit projects.conf
#   -l, --list       List configured projects
#   -h, --help       Show this help

# ── Help ──
if [[ "$1" == "--help" || "$1" == "-h" ]]; then
    cat << 'HELP'
myclaude — Unified Claude Code launcher

Usage:
  myclaude              Launch the door → project → entry mode menu
  myclaude --list       List configured projects
  myclaude --edit       Edit ~/.myclaude/projects.conf
  myclaude --help       Show this help

Three doors:
  Business    zingcontrol namespace only (cannot see personal)
  Personal    reads both namespaces, writes only utahdiver
  Bench       no namespace, no project context, the shed out back

Entry modes (after picking a project):
  Start fresh        New session, clean context
  Resume             Continue last session in this project
  Load handoff       Read most recent handoff MD, then work
  Status check       Read-only project state report

Config files:
  ~/.myclaude/projects.conf       Project list
  ~/.myclaude/mcp/business.json   MCP servers for Business door
  ~/.myclaude/mcp/personal.json   MCP servers for Personal door
  ~/.myclaude/mcp/bench.json      MCP servers for Bench door (empty)
  ~/.myclaude/history.log         Session launch history
HELP
    exit 0
fi

# ── Machine-specific node + claude-code resolution ──
# Prefers whichever node install (Homebrew or nvm) has @anthropic-ai/claude-code
# actually present. Homebrew wins ties. Surfaces specific install state on error.
HB_NODE="/opt/homebrew/bin/node"
HB_CLI="/opt/homebrew/lib/node_modules/@anthropic-ai/claude-code/cli.js"
NVM_NODE=""
NVM_CLI=""
if [[ -d "$HOME/.nvm/versions/node" ]]; then
    typeset _latest_nvm="$(ls "$HOME/.nvm/versions/node/" 2>/dev/null | sort -V | tail -1)"
    if [[ -n "$_latest_nvm" ]]; then
        NVM_NODE="$HOME/.nvm/versions/node/$_latest_nvm/bin/node"
        NVM_CLI="$HOME/.nvm/versions/node/$_latest_nvm/lib/node_modules/@anthropic-ai/claude-code/cli.js"
    fi
fi

if [[ -x "$HB_NODE" && -f "$HB_CLI" ]]; then
    NODE_BIN="$HB_NODE"
    CLI_JS="$HB_CLI"
    export PATH="/opt/homebrew/bin:$HOME/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
elif [[ -n "$NVM_NODE" && -x "$NVM_NODE" && -f "$NVM_CLI" ]]; then
    NODE_BIN="$NVM_NODE"
    CLI_JS="$NVM_CLI"
    export PATH="${NVM_NODE%/node}:$HOME/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
else
    echo "Error: claude-code not found in any node installation."
    echo "  Homebrew node:  $([[ -x $HB_NODE ]] && echo present || echo missing)"
    echo "  Homebrew cli.js: $([[ -f $HB_CLI ]] && echo present || echo missing) ($HB_CLI)"
    echo "  nvm node:       $([[ -n $NVM_NODE && -x $NVM_NODE ]] && echo "present ($NVM_NODE)" || echo missing)"
    echo "  nvm cli.js:     $([[ -n $NVM_CLI && -f $NVM_CLI ]] && echo present || echo missing)"
    echo ""
    echo "Install with: npm install -g @anthropic-ai/claude-code"
    exit 1
fi

if [[ ! -x "$NODE_BIN" ]]; then
    echo "Error: node not found at $NODE_BIN"
    exit 1
fi
if [[ ! -f "$CLI_JS" ]]; then
    echo "Error: claude cli.js not found at $CLI_JS"
    echo "Reinstall: npm install -g @anthropic-ai/claude-code"
    exit 1
fi

CONF_DIR="$HOME/.myclaude"
CONF_FILE="$CONF_DIR/projects.conf"
MCP_DIR="$CONF_DIR/mcp"
HISTORY_LOG="$CONF_DIR/history.log"
MACHINE_NAME="${MYCLAUDE_MACHINE:-$(hostname -s)}"

# ── 1Password env wrap (Phase 1.7b, 2026-04-07) ──
# If `op` CLI is paired and ~/.myclaude/op-env exists, wrap claude with
# `op run --env-file=...` so MCP server subprocesses inherit secrets from
# 1Password instead of literal values in per-door MCP config files.
# Falls through to direct exec if op isn't available — broken 1Password
# must not brick the launcher.
OP_ENV_FILE="$CONF_DIR/op-env"
typeset -a OP_WRAP
if command -v op >/dev/null 2>&1 && [[ -f "$OP_ENV_FILE" ]] && op account list >/dev/null 2>&1; then
    OP_WRAP=(op run --env-file="$OP_ENV_FILE" --)
else
    OP_WRAP=()
fi

# ── Door colors (consistent across machines) ──
C_BUSINESS="\e[38;5;214m"   # orange — hard boundary
C_PERSONAL="\e[38;5;75m"    # pale blue — the whole picture
C_BENCH="\e[38;5;250m"      # gray — the shed
C_MACHINE="\e[38;5;46m"     # bright green — machine header
C_BOLD="\e[1m"
C_DIM="\e[2m"
C_REV="\e[7m"
C_UL="\e[4m"
C_RESET="\e[0m"

# ── Config bootstrap ──
if [[ ! -f "$CONF_FILE" ]]; then
    mkdir -p "$CONF_DIR"
    cat > "$CONF_FILE" << 'DEFAULTCONF'
# myclaude unified project configuration
# Format: key|door|label|path
# Door: Business, Personal, or Bench
b|Bench|Bench|~/bench
DEFAULTCONF
    echo "Created default config at $CONF_FILE"
fi

# ── MCP config bootstrap (empty stubs if missing) ──
mkdir -p "$MCP_DIR"
for door in business personal bench; do
    if [[ ! -f "$MCP_DIR/$door.json" ]]; then
        echo '{"mcpServers": {}}' > "$MCP_DIR/$door.json"
    fi
done

# ── Edit flag ──
if [[ "$1" == "--edit" || "$1" == "-e" ]]; then
    ${EDITOR:-nano} "$CONF_FILE"
    echo "Config updated."
    exit 0
fi

# ── List flag ──
if [[ "$1" == "--list" || "$1" == "-l" ]]; then
    echo "myclaude projects:"
    cat "$CONF_FILE" | grep -v "^#" | grep -v "^$" | while IFS='|' read -r key door label proj_path; do
        expanded="${proj_path/#\~/$HOME}"
        [[ -d "$expanded" ]] && ok="✓" || ok="✗"
        echo "  [$door] ($key) $label → $proj_path $ok"
    done
    exit 0
fi

# ── Load projects ──
typeset -a KEYS DOORS LABELS PATHS
idx=0

while IFS='|' read -r key door label proj_path; do
    [[ "$key" == "#"* || -z "$key" ]] && continue
    expanded="${proj_path/#\~/$HOME}"
    [[ ! -d "$expanded" ]] && continue  # skip projects whose directory doesn't exist on this machine
    idx=$((idx + 1))
    KEYS[$idx]="$key"
    DOORS[$idx]="$door"
    LABELS[$idx]="$label"
    PATHS[$idx]="$proj_path"
done < "$CONF_FILE"

# ── Color helper ──
door_color() {
    case "$1" in
        Business) print -n "$C_BUSINESS" ;;
        Personal) print -n "$C_PERSONAL" ;;
        Bench)    print -n "$C_BENCH" ;;
        *)        print -n "$C_BENCH" ;;
    esac
}

# ── Door → MCP config path ──
door_mcp_config() {
    case "$1" in
        Business) print -n "$MCP_DIR/business.json" ;;
        Personal) print -n "$MCP_DIR/personal.json" ;;
        Bench)    print -n "$MCP_DIR/bench.json" ;;
        *)        print -n "$MCP_DIR/bench.json" ;;
    esac
}

# ── Terminal title ──
set_title() {
    printf '\e]1;%s\a' "$1"
    printf '\e]2;%s\a' "$1"
}

# ── History logging ──
log_launch() {
    typeset door="$1" label="$2" entry="$3"
    typeset ts=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    echo "$ts | $door | $label | $entry | $MACHINE_NAME" >> "$HISTORY_LOG"
}

# ── Hotkey highlight ──
highlight_key() {
    typeset key="$1" label="$2" active="$3" color="$4"
    typeset key_lower="${key:l}"
    typeset result="" found=0 i ch ch_lower

    for (( i=0; i<${#label}; i++ )); do
        ch="${label:$i:1}"
        ch_lower="${ch:l}"
        if [[ $found -eq 0 && "$ch_lower" == "$key_lower" ]]; then
            if [[ "$active" == "1" ]]; then
                result="${result}\e[1;7;4m${ch}\e[0;1;7m"
            else
                result="${result}${color}\e[1;4m${ch}${C_RESET}"
            fi
            found=1
        else
            result="${result}${ch}"
        fi
    done
    [[ $found -eq 0 ]] && result="${result} [${key}]"
    print -n "$result"
}

# ── Door selection menu ──
select_door() {
    typeset -a doors=("Business" "Personal" "Bench" "Quit")
    typeset sel=1 total=4

    while true; do
        printf '\e[H\e[2J'
        echo ""
        printf "  ${C_BOLD}myclaude${C_RESET}  ${C_MACHINE}${C_BOLD}${MACHINE_NAME}${C_RESET}\n"
        echo "  ────────────────────────────"
        echo ""

        for (( i=1; i<=total; i++ )); do
            typeset d="${doors[$i]}"
            typeset color=$(door_color "$d")

            if [[ $i -eq $sel ]]; then
                printf "  ${C_BOLD}${C_REV}  ${d}  ${C_RESET}\n"
            elif [[ "$d" == "Quit" ]]; then
                printf "    ${C_DIM}${d}${C_RESET}\n"
            else
                printf "    ${color}${d}${C_RESET}\n"
            fi
        done

        echo ""
        echo "  ────────────────────────────"
        printf "  ${C_DIM}↑↓ navigate  Enter select${C_RESET}\n"

        IFS= read -r -k1 key
        if [[ "$key" == $'\e' ]]; then
            IFS= read -r -k1 -t 0.05 byte2 2>/dev/null
            if [[ "$byte2" == "[" ]]; then
                IFS= read -r -k1 -t 0.05 byte3 2>/dev/null
                case "$byte3" in
                    A) sel=$((sel - 1)); [[ $sel -lt 1 ]] && sel=$total ;;
                    B) sel=$((sel + 1)); [[ $sel -gt $total ]] && sel=1 ;;
                esac
            fi
            continue
        fi

        if [[ "$key" == $'\n' || "$key" == $'\r' ]]; then
            case "${doors[$sel]}" in
                Quit)
                    /usr/bin/tput cnorm 2>/dev/null
                    set_title "Terminal"
                    printf '\e[H\e[2J'
                    exit 0
                    ;;
                *)
                    SELECTED_DOOR="${doors[$sel]}"
                    return 0
                    ;;
            esac
        fi

        # Quick keys
        case "${key:l}" in
            b) SELECTED_DOOR="Business"; return 0 ;;
            p) SELECTED_DOOR="Personal"; return 0 ;;
            e) SELECTED_DOOR="Bench"; return 0 ;;
            q) /usr/bin/tput cnorm 2>/dev/null; set_title "Terminal"; printf '\e[H\e[2J'; exit 0 ;;
        esac
    done
}

# ── Project selection within a door ──
select_project() {
    typeset door="$1"
    typeset color=$(door_color "$door")

    # Bench goes straight to its own directory
    if [[ "$door" == "Bench" ]]; then
        SELECTED_PROJECT_LABEL="Bench"
        SELECTED_PROJECT_PATH="$HOME/bench"
        SELECTED_PROJECT_DOOR="Bench"
        return 0
    fi

    # Gather projects for this door
    typeset -a p_keys p_labels p_paths
    typeset pidx=0

    for (( i=1; i<=idx; i++ )); do
        if [[ "${DOORS[$i]}" == "$door" ]]; then
            pidx=$((pidx + 1))
            p_keys[$pidx]="${KEYS[$i]}"
            p_labels[$pidx]="${LABELS[$i]}"
            p_paths[$pidx]="${PATHS[$i]}"
        fi
    done

    # Add Back option
    pidx=$((pidx + 1))
    p_keys[$pidx]="←"
    p_labels[$pidx]="Back"
    p_paths[$pidx]=""

    typeset sel=1 total=$pidx

    while true; do
        printf '\e[H\e[2J'
        echo ""
        printf "  ${C_BOLD}myclaude${C_RESET}  ${C_MACHINE}${C_BOLD}${MACHINE_NAME}${C_RESET}\n"
        printf "  ${color}${C_BOLD}${door}${C_RESET}\n"
        echo "  ────────────────────────────"
        echo ""

        for (( j=1; j<=total; j++ )); do
            if [[ $j -eq $sel ]]; then
                printf "  ${C_BOLD}${C_REV}  "
                if [[ "${p_labels[$j]}" == "Back" ]]; then
                    printf "← Back"
                else
                    highlight_key "${p_keys[$j]}" "${p_labels[$j]}" "1" "$color"
                fi
                printf "  ${C_RESET}\n"
            else
                printf "    "
                if [[ "${p_labels[$j]}" == "Back" ]]; then
                    printf "${C_DIM}← Back${C_RESET}"
                else
                    highlight_key "${p_keys[$j]}" "${p_labels[$j]}" "0" "$color"
                fi
                printf "\n"
            fi
        done

        echo ""
        echo "  ────────────────────────────"
        printf "  ${C_DIM}↑↓ navigate  Enter select  hotkey  ← back${C_RESET}\n"

        IFS= read -r -k1 key
        if [[ "$key" == $'\e' ]]; then
            IFS= read -r -k1 -t 0.05 byte2 2>/dev/null
            if [[ "$byte2" == "[" ]]; then
                IFS= read -r -k1 -t 0.05 byte3 2>/dev/null
                case "$byte3" in
                    A) sel=$((sel - 1)); [[ $sel -lt 1 ]] && sel=$total ;;
                    B) sel=$((sel + 1)); [[ $sel -gt $total ]] && sel=1 ;;
                    D) return 1 ;;  # left arrow = back
                esac
            fi
            continue
        fi

        if [[ "$key" == $'\n' || "$key" == $'\r' ]]; then
            if [[ "${p_labels[$sel]}" == "Back" ]]; then
                return 1
            fi
            SELECTED_PROJECT_LABEL="${p_labels[$sel]}"
            SELECTED_PROJECT_PATH="${p_paths[$sel]}"
            SELECTED_PROJECT_DOOR="$door"
            return 0
        fi

        # Hotkeys
        typeset key_lower="${key:l}"
        for (( j=1; j<total; j++ )); do
            if [[ "${p_keys[$j]:l}" == "$key_lower" ]]; then
                SELECTED_PROJECT_LABEL="${p_labels[$j]}"
                SELECTED_PROJECT_PATH="${p_paths[$j]}"
                SELECTED_PROJECT_DOOR="$door"
                return 0
            fi
        done
    done
}

# ── Entry mode selection ──
select_entry_mode() {
    typeset door="$1" label="$2"
    typeset color=$(door_color "$door")

    # Bench always starts fresh
    if [[ "$door" == "Bench" ]]; then
        SELECTED_ENTRY="fresh"
        return 0
    fi

    typeset -a modes=("Start fresh" "Resume last session" "Load handoff" "Status check" "Back")
    typeset -a mode_keys=("fresh" "resume" "handoff" "status" "back")
    typeset sel=1 total=5

    while true; do
        printf '\e[H\e[2J'
        echo ""
        printf "  ${C_BOLD}myclaude${C_RESET}  ${C_MACHINE}${C_BOLD}${MACHINE_NAME}${C_RESET}\n"
        printf "  ${color}${C_BOLD}${door}${C_RESET} → ${C_BOLD}${label}${C_RESET}\n"
        echo "  ────────────────────────────"
        echo ""

        for (( j=1; j<=total; j++ )); do
            if [[ $j -eq $sel ]]; then
                printf "  ${C_BOLD}${C_REV}  ${modes[$j]}  ${C_RESET}\n"
            elif [[ "${modes[$j]}" == "Back" ]]; then
                printf "    ${C_DIM}← Back${C_RESET}\n"
            else
                printf "    ${modes[$j]}\n"
            fi
        done

        echo ""
        echo "  ────────────────────────────"
        printf "  ${C_DIM}↑↓ navigate  Enter select  ← back${C_RESET}\n"

        IFS= read -r -k1 key
        if [[ "$key" == $'\e' ]]; then
            IFS= read -r -k1 -t 0.05 byte2 2>/dev/null
            if [[ "$byte2" == "[" ]]; then
                IFS= read -r -k1 -t 0.05 byte3 2>/dev/null
                case "$byte3" in
                    A) sel=$((sel - 1)); [[ $sel -lt 1 ]] && sel=$total ;;
                    B) sel=$((sel + 1)); [[ $sel -gt $total ]] && sel=1 ;;
                    D) return 1 ;;
                esac
            fi
            continue
        fi

        if [[ "$key" == $'\n' || "$key" == $'\r' ]]; then
            if [[ "${mode_keys[$sel]}" == "back" ]]; then
                return 1
            fi
            SELECTED_ENTRY="${mode_keys[$sel]}"
            return 0
        fi
    done
}

# ── Launch Claude ──
launch_claude() {
    typeset door="$1" label="$2" proj_path="$3" entry="$4"
    typeset color=$(door_color "$door")
    typeset target="${proj_path/#\~/$HOME}"
    typeset mcp_config=$(door_mcp_config "$door")

    # Export session identity for Claude Code's statusLine command to read.
    # See ~/.claude/settings.json statusLine.command — uses these env vars to
    # render a stable [Project] | [Machine] header instead of cwd basename + hostname.
    # Falls back to cwd/hostname when not set (e.g., direct claude launches).
    export CLAUDE_PROJECT_LABEL="$label"
    export CLAUDE_MACHINE_LABEL="$MACHINE_NAME"
    export CLAUDE_DOOR="$door"

    if [[ ! -d "$target" ]]; then
        echo "  Directory not found: $proj_path"
        sleep 2
        return 1
    fi

    /usr/bin/tput cnorm 2>/dev/null
    set_title "${label} [${door}] — ${MACHINE_NAME}"

    printf '\e[H\e[2J'
    echo ""
    printf "  ${color}${C_BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${C_RESET}\n"
    printf "  ${color}${C_BOLD}${label}${C_RESET}\n"
    printf "  ${door} · ${C_MACHINE}${C_BOLD}${MACHINE_NAME}${C_RESET} · ${C_DIM}${entry}${C_RESET}\n"
    printf "  ${color}${C_BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${C_RESET}\n"
    echo ""

    cd "$target" || { echo "  Failed to cd to $target"; sleep 2; return 1; }

    # Pre-flight sync check — fetches repos, reports staleness
    typeset preflight_script="$HOME/claude-projects/claude-state/hooks/preflight.sh"
    if [[ -x "$preflight_script" ]]; then
        bash "$preflight_script"
    fi

    # Log the launch
    log_launch "$door" "$label" "$entry"

    # Build common claude flags: per-door MCP config + strict mode
    typeset -a claude_args
    claude_args=(--mcp-config "$mcp_config" --strict-mcp-config)

    # Entry mode determines how Claude starts
    case "$entry" in
        fresh)
            "${OP_WRAP[@]}" "$NODE_BIN" "$CLI_JS" "${claude_args[@]}"
            ;;
        resume)
            "${OP_WRAP[@]}" "$NODE_BIN" "$CLI_JS" "${claude_args[@]}" --continue
            ;;
        handoff)
            # Look for most recent handoff file and feed it as initial prompt (positional arg)
            typeset handoff_file=""
            if [[ "$door" == "Business" ]]; then
                handoff_file=$(ls -t "$HOME/Library/CloudStorage/GoogleDrive-matt@zingcontrol.com/My Drive/00-Operator/Handoff-00-Operator/"*.md 2>/dev/null | head -1)
            elif [[ "$door" == "Personal" ]]; then
                handoff_file=$(ls -t "$HOME/Library/CloudStorage/GoogleDrive-matt@utahdiver.com/My Drive/00-Personal/Handoff-00-Personal/"*.md 2>/dev/null | head -1)
            fi
            if [[ -n "$handoff_file" && -f "$handoff_file" ]]; then
                printf "  ${C_DIM}Loading: $(basename "$handoff_file")${C_RESET}\n\n"
                typeset prompt_text="Review this handoff document and summarize where we left off, then ask what I want to work on:

$(cat "$handoff_file")"
                "${OP_WRAP[@]}" "$NODE_BIN" "$CLI_JS" "${claude_args[@]}" "$prompt_text"
            else
                printf "  ${C_DIM}No handoff file found. Starting fresh.${C_RESET}\n\n"
                "${OP_WRAP[@]}" "$NODE_BIN" "$CLI_JS" "${claude_args[@]}"
            fi
            ;;
        status)
            "${OP_WRAP[@]}" "$NODE_BIN" "$CLI_JS" "${claude_args[@]}" "Status check: Show me current state of this project. What's in progress, what's blocked, what's next. Read any state files (CURRENT_STATE_HANDOFF.md, README, recent commits). Do not start work — just report."
            ;;
    esac

    typeset rc=$?

    # Post-session: auto-commit and push claude-state if anything changed
    typeset state_repo="$HOME/claude-projects/claude-state"
    if [[ -d "$state_repo/.git" ]]; then
        typeset state_dirty=$(git -C "$state_repo" status --porcelain 2>/dev/null | wc -l | tr -d ' ')
        if [[ "$state_dirty" -gt 0 ]]; then
            printf "\n  ${C_DIM}Syncing claude-state...${C_RESET}\n"
            git -C "$state_repo" add -A 2>/dev/null
            git -C "$state_repo" commit -m "Auto-sync: ${label} session on ${MACHINE_NAME} ($(date +%Y-%m-%d\ %H:%M))" --quiet 2>/dev/null
            git -C "$state_repo" push --quiet 2>/dev/null && \
                printf "  ${C_DIM}claude-state pushed.${C_RESET}\n" || \
                printf "  ${C_DIM}claude-state commit saved locally (push failed).${C_RESET}\n"
        fi
    fi

    if [[ $rc -ne 0 ]]; then
        echo ""
        echo "  claude exited with code $rc"
        echo "  Press any key to return to menu..."
        read -k1
    fi
}

# ── Main loop ──
set_title "myclaude — ${MACHINE_NAME}"
/usr/bin/tput civis 2>/dev/null
trap '/usr/bin/tput cnorm 2>/dev/null' EXIT INT TERM

while true; do
    # Step 1: Pick a door
    select_door
    typeset door="$SELECTED_DOOR"

    # Step 2: Pick a project (Bench skips this)
    if ! select_project "$door"; then
        continue  # Back pressed — return to door selection
    fi

    # Step 3: Pick entry mode (Bench skips this)
    if ! select_entry_mode "$SELECTED_PROJECT_DOOR" "$SELECTED_PROJECT_LABEL"; then
        continue  # Back pressed — return to project selection
    fi

    # Step 4: Launch
    launch_claude "$SELECTED_PROJECT_DOOR" "$SELECTED_PROJECT_LABEL" "$SELECTED_PROJECT_PATH" "$SELECTED_ENTRY"
done
